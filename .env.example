# ============================================
# Lobe Chat 环境变量配置示例
# ============================================
# ⚠️ 重要提示：
# 1. 不要将此文件提交到 GitHub
# 2. 实际部署时请在 Vercel 项目设置中添加环境变量
# 3. 将此文件复制为 .env.local 用于本地开发
# ============================================

# --------------------------------------------
# 应用基础配置
# --------------------------------------------
# 你的应用 URL（必需）
# 部署后替换为你的 Vercel 域名
APP_URL=https://your-app.vercel.app

# --------------------------------------------
# EvoLink API 配置
# --------------------------------------------
# EvoLink API 密钥（必需）
# 获取方式：登录 https://api.evolink.ai → API Keys → 复制密钥
OPENAI_API_KEY=your_evolink_api_key_here

# EvoLink API 地址（必需，兼容 OpenAI 格式）
OPENAI_API_BASE_URL=https://api.evolink.ai/v1

# 默认模型（可选）
# 常见模型：gemini-1.5-pro, gemini-1.5-flash, gpt-4o, gpt-4o-mini
DEFAULT_MODEL=gemini-1.5-pro

# --------------------------------------------
# 数据库配置（可选 - 用于服务端数据库）
# --------------------------------------------
# 如果不需要服务端数据库，可以忽略以下配置
# 参考 LOBEHUB_DEPLOYMENT.md 了解完整配置

# Postgres 数据库连接 URL（Serverless Postgres）
# DATABASE_URL=postgres://username:password@host:port/database

# 密钥加密密钥（用于加密存储的 API Key）
# KEY_VAULTS_SECRET=your_secret_key_here

# --------------------------------------------
# 身份验证配置（可选）
# --------------------------------------------
# 会话加密密钥
# AUTH_SECRET=your_auth_secret_here

# JWT 签名密钥
# JWKS_KEY={"keys":[...]}

# --------------------------------------------
# S3 存储配置（可选 - 用于文件存储）
# --------------------------------------------
# S3 访问密钥
# S3_ACCESS_KEY_ID=your_access_key_here

# S3 密钥
# S3_SECRET_ACCESS_KEY=your_secret_access_key_here

# 存储桶名称
# S3_BUCKET=your_bucket_name

# S3 端点（如 Cloudflare R2）
# S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com

# 桶区域（可选）
# S3_REGION=us-east-1

# --------------------------------------------
# 高级配置（可选）
# --------------------------------------------
# 应用标题
# APP_NAME=Lobe Chat

# 应用描述
# APP_DESCRIPTION=Open-source ChatGPT/Claude alternative

# 语言设置
# LANG=zh-CN

# 启用调试模式（生产环境请设置为 false）
# DEBUG=false

# 最大并发请求数
# MAX_CONCURRENT_REQUESTS=5
